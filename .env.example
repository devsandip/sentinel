# Sentinel configuration. Copy to .env for local live-LLM runs.
# The public demo needs none of these (default is scripted, zero cost).

# Narration provider: templated | anthropic | openai
MODEL_PROVIDER=templated

# Live-LLM mode only. Keys stay server-side; never expose to the client.
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=

# Hard dollar ceiling for live mode (falls back to scripted when reached).
LIVE_MODE_MONTHLY_CAP=5

# Vector store for RAG: local (default, free TF-IDF) | pgvector (real AWS RDS).
# The default local store needs none of the below. To use the provisioned AWS
# store, install the extra (uv sync --extra pgvector) and set:
# SENTINEL_VECTOR_STORE=pgvector
# SENTINEL_PGVECTOR_HOST=sentinel-vectordb.<...>.us-east-1.rds.amazonaws.com
# SENTINEL_PGVECTOR_SECRET_ARN=arn:aws:secretsmanager:...   # password stays in Secrets Manager
# SENTINEL_PGVECTOR_DBNAME=sentinel
# Requires AWS creds with Bedrock InvokeModel + secretsmanager:GetSecretValue.
