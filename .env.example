# Sentinel configuration. Copy to .env for local live-LLM runs.
# The public demo needs none of these (default is scripted, zero cost).

# Narration provider: templated | anthropic | openai
MODEL_PROVIDER=templated

# Live-LLM mode only. Keys stay server-side; never expose to the client.
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=

# Hard dollar ceiling for live mode (falls back to scripted when reached).
LIVE_MODE_MONTHLY_CAP=5
